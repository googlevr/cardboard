<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryDark">@color/color_primary_dark</item>
        <item name="colorAccent">@color/color_accent</item>
        <item name="icon">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="UiButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/rippleable</item>
        <item name="android:padding">9dip</item>
    </style>

    <style name="text_20sp_sans_serif_medium">
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="text_14sp_sans_serif">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="text_16sp_sans_serif_opacity">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/grey</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="text_24sp_sans_serif_medium_opacity">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/grey</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="VerticalDivider">
        <item name="android:layout_width">1px</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@android:color/darker_gray</item>
    </style>

    <style name="ActionbarTabText">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tab_unselected_text_color</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="MyLibAppNameText">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/darker_text_color</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SettingsHeadsetLabel" parent="@style/text_16sp_sans_serif_opacity">
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SettingsHeadsetModel" parent="@style/text_24sp_sans_serif_medium_opacity">
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="SettingsHeadsetVendor" parent="@android:style/TextAppearance.Medium">
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/darker_gray</item>
    </style>

    <style name="SettingsActionButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/orange</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FFF</item>
    </style>

    <style name="TutorialText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FFF</item>
    </style>

    <style name="AboutItem" parent="@style/text_16sp_sans_serif_opacity">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_centerInParent">true</item>
    </style>

    <style name="GetAppPriceText" parent="@style/MyLibAppNameText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#89000000</item>
    </style>
</resources>
